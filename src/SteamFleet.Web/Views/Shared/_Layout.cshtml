@using SteamFleet.Persistence.Helpers
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SteamFleet</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    string NavClass(string controller, string? action = null)
    {
        var controllerMatch = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var actionMatch = action is null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return controllerMatch && actionMatch ? "sf-nav-link is-active" : "sf-nav-link";
    }

    var canUseAdminTools = User.Identity?.IsAuthenticated == true &&
                           (User.IsInRole(Roles.SuperAdmin) || User.IsInRole(Roles.Admin));
}
<div class="sf-bg-glow"></div>
<header class="sf-topbar">
    <div class="container-fluid d-flex align-items-center justify-content-between gap-3">
        <a class="sf-brand" asp-controller="Accounts" asp-action="Index">
            <span class="sf-brand-mark">SF</span>
            <span class="sf-brand-text">SteamFleet Control</span>
        </a>
        <nav class="sf-nav d-flex align-items-center gap-2 flex-wrap">
            <a class="@NavClass("Accounts", "Index")" asp-controller="Accounts" asp-action="Index">Аккаунты</a>
            <a class="@NavClass("Jobs", "Index")" asp-controller="Jobs" asp-action="Index">Задачи</a>
            <a class="@NavClass("Audit", "Index")" asp-controller="Audit" asp-action="Index">Аудит</a>
            @if (canUseAdminTools)
            {
                <a class="sf-nav-link" href="/swagger" target="_blank" rel="noopener">Swagger</a>
                <a class="sf-nav-link" href="/hangfire" target="_blank" rel="noopener">Hangfire</a>
            }
        </nav>
        <div class="d-flex align-items-center gap-2">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="sf-user" title="Текущий пользователь">@User.Identity.Name</span>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn sf-btn sf-btn-danger btn-sm">Выйти</button>
                </form>
            }
            else
            {
                <a class="btn sf-btn sf-btn-primary btn-sm" asp-controller="Auth" asp-action="Login">Войти</a>
            }
        </div>
    </div>
</header>

<main class="container-fluid sf-main">
    @if (TempData["Success"] is string success)
    {
        <div class="sf-alert sf-alert-success d-flex justify-content-between align-items-start gap-3">
            <div>@success</div>
            <button type="button" class="btn-close btn-close-white sf-alert-close" aria-label="Закрыть" onclick="this.closest('.sf-alert')?.remove();"></button>
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="sf-alert sf-alert-danger d-flex justify-content-between align-items-start gap-3">
            <div>@error</div>
            <button type="button" class="btn-close btn-close-white sf-alert-close" aria-label="Закрыть" onclick="this.closest('.sf-alert')?.remove();"></button>
        </div>
    }

    <div class="sf-shell">
        @RenderBody()
    </div>
</main>

<footer class="sf-footer">
    <div class="container-fluid d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span>SteamFleet Control</span>
        <span class="sf-subtitle">Локальная панель управления аккаунтами, задачами и аудитом</span>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
