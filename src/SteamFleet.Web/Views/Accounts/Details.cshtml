@model AccountDto
@{
    ViewData["Title"] = "Карточка аккаунта";
    var games = ViewData["Games"] as AccountGamesPageResult ?? new AccountGamesPageResult();
    var familySnapshot = ViewData["FamilySnapshot"] as AccountFamilySnapshotDto ?? new AccountFamilySnapshotDto();
    var gamesScope = ViewData["GamesScope"] as string ?? "all";
    var gamesQuery = ViewData["GamesQuery"] as string ?? string.Empty;
    var friendInvite = ViewData["FriendInviteLink"] as FriendInviteLinkDto;
    var friendsSnapshot = ViewData["FriendsSnapshot"] as AccountFriendsSnapshotDto ?? new AccountFriendsSnapshotDto();
    var friendSourceCandidates = ViewData["FriendSourceCandidates"] as List<AccountDto> ?? [];
    var familyInviteTargets = ViewData["FamilyInviteTargets"] as List<AccountDto> ?? [];
    var familyInviteSources = ViewData["FamilyInviteSources"] as List<AccountDto> ?? [];
    var passwordChangePending = ViewData["PasswordChangePending"] as bool? ?? false;
    var pendingPasswordRequestId = ViewData["PasswordChangePendingRequestId"] as string;
    var pendingPasswordExpiresAt = ViewData["PasswordChangePendingExpiresAt"] as string;
    var openPasswordConfirmationModal = string.Equals(TempData["PasswordConfirmationModal"] as string, "1", StringComparison.Ordinal);
    var openGeneratedPasswordModal = string.Equals(TempData["PasswordGeneratedModal"] as string, "1", StringComparison.Ordinal);
    var generatedPasswordValue = TempData["PasswordGeneratedValue"] as string;
    pendingPasswordRequestId ??= TempData["PasswordConfirmationRequestId"] as string;
    pendingPasswordExpiresAt ??= TempData["PasswordConfirmationExpiresAt"] as string;
    var riskWarning = Model.AutoRetryAfter is not null && Model.AutoRetryAfter > DateTimeOffset.UtcNow
        ? $"Повышенный риск: {Model.LastRiskReasonCode ?? "Unknown"}. Автоматические повторы безопаснее после {Model.AutoRetryAfter:dd.MM.yyyy HH:mm:ss}."
        : null;
    var currentGamesPage = games.Page <= 0 ? 1 : games.Page;
    var gamesTotalPages = games.PageSize > 0
        ? Math.Max(1, (int)Math.Ceiling(games.TotalCount / (double)games.PageSize))
        : 1;
}

<section class="sf-page-header">
    <div>
        <h1 class="sf-page-title">@Model.LoginName</h1>
        <div class="sf-page-subtitle">Карточка аккаунта: безопасность, семья, друзья, игры и риск-профиль.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn sf-btn sf-btn-secondary btn-sm" asp-action="Index">К списку</a>
        <a class="btn sf-btn sf-btn-secondary btn-sm" asp-action="Edit" asp-route-id="@Model.Id">Редактировать</a>
        <form asp-action="Archive" asp-route-id="@Model.Id" method="post">
            <button class="btn sf-btn sf-btn-danger btn-sm" type="submit">Архивировать</button>
        </form>
    </div>
</section>

<section class="sf-card mb-3">
    <div class="sf-card-head d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h2 class="sf-title h4 mb-0">@Model.LoginName</h2>
            <div class="sf-subtitle">@Model.DisplayName</div>
            <div class="sf-subtitle">SteamId: @Model.SteamId64</div>
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <span class="sf-badge sf-badge-muted">@Model.Status</span>
            <span class="sf-badge sf-badge-owned">Risk: @Model.RiskLevel</span>
            @if (!string.IsNullOrWhiteSpace(Model.ProfileUrl))
            {
                <a class="btn sf-btn sf-btn-primary btn-sm" href="@Model.ProfileUrl" target="_blank" rel="noopener">Открыть профиль</a>
            }
        </div>
    </div>
    <div class="sf-card-body">
        <div class="sf-tab-nav">
            <a class="sf-tab active" href="#overview">Обзор</a>
            <a class="sf-tab" href="#security">Безопасность</a>
            <a class="sf-tab" href="#family">Семья</a>
            <a class="sf-tab" href="#friends">Друзья</a>
            <a class="sf-tab" href="#games">Игры</a>
        </div>
        <div class="sf-grid">
            <div class="sf-col-3">
                <div class="sf-kpi">
                    <div class="sf-subtitle">Статус</div>
                    <div class="sf-kpi-value">@Model.Status</div>
                </div>
            </div>
            <div class="sf-col-3">
                <div class="sf-kpi">
                    <div class="sf-subtitle">Игр в кэше</div>
                    <div class="sf-kpi-value">@Model.GamesCount</div>
                </div>
            </div>
            <div class="sf-col-3">
                <div class="sf-kpi">
                    <div class="sf-subtitle">Семья</div>
                    <div class="sf-kpi-value">@Model.FamilyAccountsCount</div>
                </div>
            </div>
            <div class="sf-col-3">
                <div class="sf-kpi">
                    <div class="sf-subtitle">Последний успех</div>
                    <div class="sf-kpi-value fs-6">@Model.LastSuccessAt?.ToString("g")</div>
                </div>
            </div>
            <div class="sf-col-3">
                <div class="sf-kpi">
                    <div class="sf-subtitle">Риск</div>
                    <div class="sf-kpi-value fs-6">@Model.RiskLevel</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="overview" class="sf-card mb-3">
    <div class="sf-card-head"><h2 class="sf-title h5 mb-0">Обзор</h2></div>
    <div class="sf-card-body">
        <table class="table table-sm align-middle mb-0">
            <tr><th>ID</th><td>@Model.Id</td></tr>
            <tr><th>Email</th><td>@Model.Email</td></tr>
            <tr><th>Папка</th><td>@Model.FolderName</td></tr>
            <tr><th>Теги</th><td>@string.Join(", ", Model.Tags)</td></tr>
            <tr>
                <th>Profile URL</th>
                <td>
                    @if (!string.IsNullOrWhiteSpace(Model.ProfileUrl))
                    {
                        <a href="@Model.ProfileUrl" target="_blank" rel="noopener">@Model.ProfileUrl</a>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </td>
            </tr>
            <tr><th>Синк игр</th><td>@Model.GamesLastSyncAt?.ToString("g")</td></tr>
            <tr><th>Последняя проверка</th><td>@Model.LastCheckAt?.ToString("g")</td></tr>
            <tr><th>Ошибка</th><td>@Model.LastErrorAt?.ToString("g")</td></tr>
            <tr><th>Уровень риска</th><td>@Model.RiskLevel</td></tr>
            <tr><th>Последняя причина риска</th><td>@Model.LastRiskReasonCode</td></tr>
            <tr><th>Auto-retry после</th><td>@Model.AutoRetryAfter?.ToString("g")</td></tr>
            <tr><th>Серия риск-сигналов</th><td>@Model.RiskSignalStreak</td></tr>
            <tr><th>Серия auth-провалов</th><td>@Model.AuthFailStreak</td></tr>
            <tr><th>Последняя sensitive-операция</th><td>@Model.LastSensitiveOpAt?.ToString("g")</td></tr>
            <tr><th>Заметка</th><td><pre>@Model.Note</pre></td></tr>
        </table>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(riskWarning))
{
    <section class="sf-card mb-3">
        <div class="sf-card-head"><h2 class="sf-title h5 mb-0">Риск-профиль аккаунта</h2></div>
        <div class="sf-card-body">
            <div class="sf-alert sf-alert-warning">@riskWarning</div>
            <div class="sf-subtitle">
                Ручные действия доступны, но автоматика (jobs) будет учитывать окно cooldown и переносить повторы.
            </div>
        </div>
    </section>
}

<section id="security" class="sf-card mb-3">
    <div class="sf-card-head"><h2 class="sf-title h5 mb-0">Безопасность</h2></div>
    <div class="sf-card-body">
        <div class="row g-3">
            <div class="col-xl-6">
                <div class="sf-subtitle mb-2">Авторизация Steam</div>
                <form asp-action="Authenticate" asp-route-id="@Model.Id" method="post" class="row g-2">
                    <div class="col-12">
                        <label class="form-label" for="auth_password">Пароль Steam (если не хранится в сервисе)</label>
                        <input id="auth_password" name="Password" type="password" class="form-control" autocomplete="new-password" />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="auth_shared">Shared Secret</label>
                        <input id="auth_shared" name="SharedSecret" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="auth_guard">Guard Code (email/mobile)</label>
                        <input id="auth_guard" name="GuardCode" class="form-control" />
                        <div class="form-text">Если код не нужен, поле можно оставить пустым.</div>
                    </div>
                    <div class="col-12 form-check">
                        <input id="auth_device" class="form-check-input" type="checkbox" name="AllowDeviceConfirmation" value="true" checked />
                        <label class="form-check-label" for="auth_device">Разрешить подтверждение устройства</label>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button class="btn sf-btn sf-btn-primary" type="submit">Авторизовать</button>
                    </div>
                </form>
                <div class="d-flex gap-2 mt-2">
                    <form asp-action="ValidateSession" asp-route-id="@Model.Id" method="post">
                        <button class="btn sf-btn sf-btn-secondary" type="submit">Проверить сессию</button>
                    </form>
                    <form asp-action="RefreshSession" asp-route-id="@Model.Id" method="post">
                        <button class="btn sf-btn sf-btn-secondary" type="submit">Обновить сессию</button>
                    </form>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="sf-subtitle mb-2">Смена пароля и завершение сессий</div>
                <div class="alert alert-dark border-secondary mb-3">
                    Схема работы: <strong>1)</strong> запускаете смену пароля, <strong>2)</strong> получаете код на почту,
                    <strong>3)</strong> вводите код в модальном окне и подтверждаете.
                </div>
                <form asp-action="ChangePassword" asp-route-id="@Model.Id" method="post" class="row g-2 mb-3">
                    <div class="col-12">
                        <label class="form-label" for="newPassword">Новый пароль (если пусто, будет сгенерирован)</label>
                        <input id="newPassword" name="NewPassword" class="form-control" autocomplete="off" />
                        <div class="form-text">Для управляемой смены можно ввести свой пароль или включить генерацию.</div>
                    </div>
                    <div class="col-12 form-check">
                        <input id="genIfEmpty" class="form-check-input" type="checkbox" name="GenerateIfEmpty" value="true" checked />
                        <label class="form-check-label" for="genIfEmpty">Генерировать пароль автоматически</label>
                    </div>
                    <div class="col-12 form-check">
                        <input id="deauthAfter" class="form-check-input" type="checkbox" name="DeauthorizeAfterChange" value="true" checked />
                        <label class="form-check-label" for="deauthAfter">После смены завершить все сессии</label>
                    </div>
                    <div class="col-12">
                        <button class="btn sf-btn sf-btn-primary" type="submit">Сменить пароль (шаг 1)</button>
                    </div>
                </form>
                @if (passwordChangePending && !string.IsNullOrWhiteSpace(pendingPasswordRequestId))
                {
                    <div class="alert alert-warning d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            Ожидается код подтверждения из письма Steam.
                            @if (!string.IsNullOrWhiteSpace(pendingPasswordExpiresAt))
                            {
                                <span>Действительно до: @pendingPasswordExpiresAt</span>
                            }
                        </div>
                        <button class="btn sf-btn sf-btn-secondary" type="button" data-bs-toggle="modal" data-bs-target="#passwordConfirmModal">
                            Ввести код
                        </button>
                    </div>
                }
                <form asp-action="DeauthorizeSessions" asp-route-id="@Model.Id" method="post">
                    <button class="btn sf-btn sf-btn-danger" type="submit">Завершить все сессии через Steam Guard</button>
                </form>

                <hr class="border-secondary my-3" />
                <div class="sf-subtitle mb-2">Steam Guard мастер (SDA-паритет)</div>
                <div id="guardWizardStatus" class="alert alert-secondary mb-2">Готово к запуску линковки.</div>
                <div class="row g-2 mb-2">
                    <div class="col-8">
                        <input id="guardPhoneInput" class="form-control" placeholder="+79991234567 (для шага phone/email)" />
                    </div>
                    <div class="col-4 d-grid">
                        <button id="guardLinkStartBtn" type="button" class="btn sf-btn sf-btn-primary">Старт линковки</button>
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-12 d-grid">
                        <button id="guardPhoneSubmitBtn" type="button" class="btn sf-btn sf-btn-secondary">Отправить телефон (шаг phone/email)</button>
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-8">
                        <input id="guardSmsInput" class="form-control" placeholder="SMS код для finalize" />
                    </div>
                    <div class="col-4 d-grid">
                        <button id="guardLinkFinalizeBtn" type="button" class="btn sf-btn sf-btn-secondary">Финализировать</button>
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-6">
                        <select id="guardRemoveScheme" class="form-select">
                            <option value="1">scheme=1 (на email-коды)</option>
                            <option value="2">scheme=2 (полное удаление)</option>
                        </select>
                    </div>
                    <div class="col-6 d-grid">
                        <button id="guardRemoveBtn" type="button" class="btn sf-btn sf-btn-danger">Удалить аутентификатор</button>
                    </div>
                </div>
                <pre id="guardWizardPayload" class="bg-black text-light p-2 rounded small mb-3" style="min-height: 96px;">{}</pre>

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="sf-subtitle mb-0">Mobile confirmations</div>
                    <div class="d-flex gap-2">
                        <button id="guardConfRefreshBtn" type="button" class="btn sf-btn sf-btn-secondary btn-sm">Обновить</button>
                        <button id="guardConfAcceptAllBtn" type="button" class="btn sf-btn sf-btn-primary btn-sm">Принять все</button>
                    </div>
                </div>
                <div id="guardConfList" class="d-flex flex-column gap-2"></div>
            </div>
        </div>
    </div>
</section>

<section id="family" class="sf-card mb-3">
    <div class="sf-card-head"><h2 class="sf-title h5 mb-0">Семейная группа</h2></div>
    <div class="sf-card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
                <div class="sf-subtitle">Источник истины: Steam Family (автоматическая синхронизация).</div>
                <div class="sf-subtitle">FamilyId: @(familySnapshot.SteamFamilyId ?? "—"), роль: @(familySnapshot.SelfRole ?? "—"), organizer: @familySnapshot.IsOrganizer</div>
                <div class="sf-subtitle">Последний sync: @familySnapshot.LastSyncedAt?.ToString("g")</div>
            </div>
            <form asp-action="SyncFamily" asp-route-id="@Model.Id" method="post">
                <button class="btn sf-btn sf-btn-primary" type="submit">Синхронизировать семью</button>
            </form>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-xl-6">
                <div class="sf-subtitle mb-2">Добавить аккаунт в семейную группу</div>
                <form asp-action="InviteToFamily" asp-route-id="@Model.Id" method="post" class="row g-2">
                    <div class="col-12">
                        <label class="form-label" for="familyTargetId">Аккаунт для приглашения</label>
                        <select id="familyTargetId" name="TargetAccountId" class="form-select" required>
                            <option value="">Выберите аккаунт</option>
                            @foreach (var candidate in familyInviteTargets)
                            {
                                <option value="@candidate.Id">
                                    @candidate.LoginName (@candidate.DisplayName) — @candidate.SteamId64
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-12 form-check">
                        <input id="inviteAsChild" class="form-check-input" type="checkbox" name="InviteAsChild" value="true" checked />
                        <label class="form-check-label" for="inviteAsChild">Пригласить как Child (иначе Adult)</label>
                    </div>
                    <div class="col-12">
                        <button class="btn sf-btn sf-btn-primary" type="submit">Отправить семейный инвайт</button>
                    </div>
                </form>
            </div>
            <div class="col-xl-6">
                <div class="sf-subtitle mb-2">Принять семейное приглашение</div>
                <form asp-action="AcceptFamilyInvite" asp-route-id="@Model.Id" method="post" class="row g-2">
                    <div class="col-12">
                        <label class="form-label" for="familySourceId">Организатор (опционально)</label>
                        <select id="familySourceId" name="SourceAccountId" class="form-select">
                            <option value="">Любой доступный pending invite</option>
                            @foreach (var source in familyInviteSources)
                            {
                                <option value="@source.Id">
                                    @source.LoginName (@source.DisplayName) — @source.SteamId64
                                </option>
                            }
                        </select>
                        <div class="form-text">Если выбран организатор, сервис примет только инвайт от него.</div>
                    </div>
                    <div class="col-12">
                        <button class="btn sf-btn sf-btn-secondary" type="submit">Принять семейный инвайт</button>
                    </div>
                </form>
            </div>
        </div>

        @if (familySnapshot.Members.Count == 0)
        {
            <div class="sf-subtitle">Данные семьи отсутствуют. Выполните синхронизацию.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Аккаунт</th>
                        <th>SteamId</th>
                        <th>Тип</th>
                        <th>Роль</th>
                        <th>Игры</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var member in familySnapshot.Members)
                    {
                        <tr>
                            <td>
                                @if (member.AccountId is not null)
                                {
                                    <a asp-action="Details" asp-route-id="@member.AccountId">@member.LoginName</a>
                                }
                                else
                                {
                                    @member.LoginName
                                }
                                <div class="sf-subtitle">@member.DisplayName</div>
                            </td>
                            <td>@member.SteamId64</td>
                            <td>
                                <span class="sf-badge @(member.IsExternal ? "sf-badge-muted" : "sf-badge-owned")">
                                    @(member.IsExternal ? "External" : "Managed")
                                </span>
                            </td>
                            <td>@(member.FamilyRole ?? "—") @(member.IsOrganizer ? "(Organizer)" : "")</td>
                            <td>@member.GamesCount</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

<section id="friends" class="sf-card mb-3">
    <div class="sf-card-head"><h2 class="sf-title h5 mb-0">Друзья и invite-links</h2></div>
    <div class="sf-card-body">
        <div class="row g-3">
            <div class="col-xl-6">
                <div class="sf-subtitle mb-2">Быстрая ссылка-приглашение</div>
                @if (!string.IsNullOrWhiteSpace(friendInvite?.InviteUrl))
                {
                    <div class="mb-2">
                        <a href="@friendInvite.InviteUrl" target="_blank">@friendInvite.InviteUrl</a>
                    </div>
                    <div class="sf-subtitle mb-2">Синхронизирован: @friendInvite.LastSyncedAt?.ToString("g")</div>
                }
                else
                {
                    <div class="sf-subtitle mb-2">Invite link пока не синхронизирован.</div>
                }
                <form asp-action="SyncFriendInviteLink" asp-route-id="@Model.Id" method="post">
                    <button class="btn sf-btn sf-btn-primary" type="submit">Синхронизировать invite-link</button>
                </form>
            </div>
            <div class="col-xl-6">
                <div class="sf-subtitle mb-2">Принять invite link</div>
                <form asp-action="AcceptFriendInvite" asp-route-id="@Model.Id" method="post" class="row g-2">
                    <div class="col-12">
                        <label class="form-label" for="sourceAccountId">Аккаунт-источник (опционально)</label>
                        <select id="sourceAccountId" name="SourceAccountId" class="form-select">
                            <option value="">Выберите аккаунт, чтобы взять его invite-link автоматически</option>
                            @foreach (var source in friendSourceCandidates)
                            {
                                var sourceInvite = source.Metadata.GetValueOrDefault("friends.invite.url");
                                var inviteInfo = string.IsNullOrWhiteSpace(sourceInvite) ? "без синка invite" : "invite готов";
                                <option value="@source.Id"
                                        data-invite="@sourceInvite">
                                    @source.LoginName (@source.DisplayName) - @inviteInfo
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="inviteUrl">Invite URL</label>
                        <input id="inviteUrl" name="InviteUrl" class="form-control" placeholder="https://s.team/p/.../... (или оставьте пустым при выборе источника)" />
                        <div class="form-text">Сценарий: выберите source-аккаунт и нажмите «Принять приглашение», сервис выполнит шаги «получить ссылку -> применить ссылку» автоматически.</div>
                    </div>
                    <div class="col-12">
                        <button class="btn sf-btn sf-btn-secondary" type="submit">Принять приглашение</button>
                    </div>
                </form>
            </div>
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="sf-subtitle">Список друзей</div>
                    <form asp-action="RefreshFriends" asp-route-id="@Model.Id" method="post">
                        <button class="btn sf-btn sf-btn-primary btn-sm" type="submit">Обновить друзей</button>
                    </form>
                </div>
                @if (friendsSnapshot.Friends.Count == 0)
                {
                    <div class="sf-subtitle">Друзья не загружены.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th>SteamId</th>
                                <th>Имя</th>
                                <th>Профиль</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var friend in friendsSnapshot.Friends)
                            {
                                <tr>
                                    <td>@friend.SteamId64</td>
                                    <td>@friend.PersonaName</td>
                                    <td><a href="@friend.ProfileUrl" target="_blank">@friend.ProfileUrl</a></td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section id="games" class="sf-card">
    <div class="sf-card-head d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h2 class="sf-title h5 mb-0">Игры (Owned + FamilyGroup)</h2>
        <form asp-action="RefreshGames" asp-route-id="@Model.Id" method="post">
            <button class="btn sf-btn sf-btn-primary btn-sm" type="submit">Обновить игры</button>
        </form>
    </div>
    <div class="sf-card-body">
        <form method="get" asp-action="Details" asp-route-id="@Model.Id" class="row g-2 mb-3">
            <div class="col-md-4">
                <input class="form-control" name="q" value="@gamesQuery" placeholder="Поиск по названию игры" />
            </div>
            <div class="col-md-3">
                <select name="scope" class="form-select">
                    <option value="all" selected="@(gamesScope == "all")">Все источники</option>
                    <option value="owned" selected="@(gamesScope == "owned")">Только owned</option>
                    <option value="family" selected="@(gamesScope == "family")">Только family</option>
                </select>
            </div>
            <div class="col-md-3">
                <input class="form-control" name="pageSize" value="@games.PageSize" type="number" min="1" max="200" />
            </div>
            <div class="col-md-2">
                <button class="btn sf-btn sf-btn-secondary w-100" type="submit">Показать</button>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.ProfileUrl))
        {
            <p class="sf-subtitle">Профиль: <a href="@Model.ProfileUrl" target="_blank">@Model.ProfileUrl</a></p>
        }

        @if (games.TotalCount == 0)
        {
            <div class="sf-empty">Список игр пуст. Нажмите <strong>Обновить игры</strong>.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                    <tr>
                        <th>AppId</th>
                        <th>Название</th>
                        <th>Источник</th>
                        <th>Доступность</th>
                        <th>Playtime (min)</th>
                        <th>Обновлено</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var game in games.Items)
                    {
                        <tr>
                            <td>@game.AppId</td>
                            <td>@game.Name</td>
                            <td>@game.SourceLoginName</td>
                            <td>
                                <span class="sf-badge @(game.Availability == AccountGameAvailability.Owned ? "sf-badge-owned" : "sf-badge-family")">
                                    @game.Availability
                                </span>
                            </td>
                            <td>@game.PlaytimeMinutes</td>
                            <td>@game.LastSyncedAt.ToString("g")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="sf-subtitle">Показано @games.Items.Count из @games.TotalCount</div>
                <div class="d-flex align-items-center gap-2">
                    <a class="btn sf-btn sf-btn-secondary btn-sm @(currentGamesPage <= 1 ? "disabled" : string.Empty)"
                       asp-action="Details"
                       asp-route-id="@Model.Id"
                       asp-route-scope="@gamesScope"
                       asp-route-q="@gamesQuery"
                       asp-route-page="@(Math.Max(1, currentGamesPage - 1))"
                       asp-route-pageSize="@games.PageSize">Назад</a>
                    <span class="sf-subtitle">Страница @currentGamesPage / @gamesTotalPages</span>
                    <a class="btn sf-btn sf-btn-secondary btn-sm @(currentGamesPage >= gamesTotalPages ? "disabled" : string.Empty)"
                       asp-action="Details"
                       asp-route-id="@Model.Id"
                       asp-route-scope="@gamesScope"
                       asp-route-q="@gamesQuery"
                       asp-route-page="@(Math.Min(gamesTotalPages, currentGamesPage + 1))"
                       asp-route-pageSize="@games.PageSize">Вперёд</a>
                </div>
            </div>
        }
    </div>
</section>

<div class="modal fade" id="passwordConfirmModal" tabindex="-1" aria-labelledby="passwordConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="passwordConfirmModalLabel">Подтверждение смены пароля</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ChangePassword" asp-route-id="@Model.Id" method="post">
                <div class="modal-body">
                    @if (string.IsNullOrWhiteSpace(pendingPasswordRequestId))
                    {
                        <div class="alert alert-warning mb-0">
                            Активный запрос не найден. Сначала запустите смену пароля (шаг 1).
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="ConfirmationRequestId" value="@pendingPasswordRequestId" />
                        <div class="mb-2">
                            <label class="form-label" for="confirmationCode">Код из письма Steam</label>
                            <input id="confirmationCode" name="ConfirmationCode" class="form-control" autocomplete="one-time-code" required />
                            <div class="form-text">Код обычно приходит на email аккаунта. Введите его без пробелов.</div>
                        </div>
                    }
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn sf-btn sf-btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn sf-btn sf-btn-primary" @(string.IsNullOrWhiteSpace(pendingPasswordRequestId) ? "disabled" : null)>Подтвердить и сменить</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="generatedPasswordModal" tabindex="-1" aria-labelledby="generatedPasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="generatedPasswordModalLabel">Новый сгенерированный пароль</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning mb-3">
                    Сохраните пароль сейчас. Окно показывается один раз после успешной смены.
                </div>
                <label class="form-label" for="generatedPasswordValue">Пароль</label>
                <div class="input-group">
                    <input id="generatedPasswordValue"
                           class="form-control"
                           value="@generatedPasswordValue"
                           readonly
                           autocomplete="off" />
                    <button class="btn sf-btn sf-btn-secondary" type="button" id="copyGeneratedPasswordButton">Копировать</button>
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn sf-btn sf-btn-primary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const tabs = Array.from(document.querySelectorAll(".sf-tab-nav .sf-tab"));
            if (!tabs.length) {
                return;
            }

            function syncActiveTab() {
                const hash = window.location.hash || "#overview";
                tabs.forEach(tab => {
                    tab.classList.toggle("active", tab.getAttribute("href") === hash);
                });
            }

            tabs.forEach(tab => {
                tab.addEventListener("click", () => {
                    setTimeout(syncActiveTab, 0);
                });
            });

            window.addEventListener("hashchange", syncActiveTab);
            syncActiveTab();
        })();

        (() => {
            const sourceSelect = document.getElementById("sourceAccountId");
            const inviteInput = document.getElementById("inviteUrl");
            if (!sourceSelect || !inviteInput) {
                return;
            }

            sourceSelect.addEventListener("change", () => {
                const option = sourceSelect.options[sourceSelect.selectedIndex];
                const invite = option?.dataset?.invite;
                if (!invite || inviteInput.value.trim().length > 0) {
                    return;
                }

                inviteInput.value = invite;
            });
        })();

        (() => {
            const shouldOpen = @((openPasswordConfirmationModal ? "true" : "false"));
            if (!shouldOpen) {
                return;
            }

            const modalEl = document.getElementById("passwordConfirmModal");
            if (!modalEl || typeof bootstrap === "undefined" || !bootstrap.Modal) {
                return;
            }

            const modal = new bootstrap.Modal(modalEl);
            modal.show();
        })();

        (() => {
            const shouldOpen = @((openGeneratedPasswordModal ? "true" : "false"));
            const modalEl = document.getElementById("generatedPasswordModal");
            const passwordInput = document.getElementById("generatedPasswordValue");
            const copyButton = document.getElementById("copyGeneratedPasswordButton");
            if (!modalEl || !passwordInput || !copyButton) {
                return;
            }

            copyButton.addEventListener("click", async () => {
                const value = passwordInput.value || "";
                if (!value) {
                    return;
                }

                try {
                    await navigator.clipboard.writeText(value);
                    copyButton.textContent = "Скопировано";
                    setTimeout(() => {
                        copyButton.textContent = "Копировать";
                    }, 1500);
                } catch {
                    passwordInput.focus();
                    passwordInput.select();
                }
            });

            if (!shouldOpen || typeof bootstrap === "undefined" || !bootstrap.Modal) {
                return;
            }

            const modal = new bootstrap.Modal(modalEl);
            modal.show();
        })();

        (() => {
            const accountId = "@Model.Id";
            const statusEl = document.getElementById("guardWizardStatus");
            const payloadEl = document.getElementById("guardWizardPayload");
            const phoneInput = document.getElementById("guardPhoneInput");
            const smsInput = document.getElementById("guardSmsInput");
            const linkStartBtn = document.getElementById("guardLinkStartBtn");
            const phoneSubmitBtn = document.getElementById("guardPhoneSubmitBtn");
            const linkFinalizeBtn = document.getElementById("guardLinkFinalizeBtn");
            const removeBtn = document.getElementById("guardRemoveBtn");
            const removeScheme = document.getElementById("guardRemoveScheme");
            const confListEl = document.getElementById("guardConfList");
            const confRefreshBtn = document.getElementById("guardConfRefreshBtn");
            const confAcceptAllBtn = document.getElementById("guardConfAcceptAllBtn");

            if (!statusEl || !payloadEl || !linkStartBtn || !phoneSubmitBtn || !linkFinalizeBtn || !removeBtn || !confListEl || !confRefreshBtn || !confAcceptAllBtn) {
                return;
            }

            function setStatus(text, level) {
                statusEl.className = "alert mb-2";
                statusEl.classList.add(level || "alert-secondary");
                statusEl.textContent = text;
            }

            function setPayload(payload) {
                payloadEl.textContent = JSON.stringify(payload || {}, null, 2);
            }

            async function api(url, options) {
                const response = await fetch(url, {
                    credentials: "include",
                    headers: {
                        "Content-Type": "application/json",
                        ...(options && options.headers ? options.headers : {})
                    },
                    ...options
                });
                const contentType = response.headers.get("content-type") || "";
                const data = contentType.includes("application/json")
                    ? await response.json()
                    : { errorMessage: await response.text() };

                if (!response.ok) {
                    throw new Error(data.errorMessage || data.message || `HTTP ${response.status}`);
                }

                return data;
            }

            function renderConfirmations(items) {
                confListEl.innerHTML = "";
                if (!items || items.length === 0) {
                    confListEl.innerHTML = '<div class="sf-subtitle">Подтверждения не найдены.</div>';
                    return;
                }

                for (const conf of items) {
                    const card = document.createElement("div");
                    card.className = "border rounded p-2 bg-dark text-light";

                    const title = document.createElement("div");
                    title.className = "fw-semibold";
                    title.textContent = `${conf.headline || "Без заголовка"} [${conf.type || "Unknown"}]`;
                    card.appendChild(title);

                    const summary = document.createElement("div");
                    summary.className = "small text-secondary";
                    summary.textContent = (conf.summary || []).join(" | ");
                    card.appendChild(summary);

                    const buttons = document.createElement("div");
                    buttons.className = "d-flex gap-2 mt-2";
                    buttons.innerHTML = `
                        <button type="button" class="btn sf-btn sf-btn-primary btn-sm">Accept</button>
                        <button type="button" class="btn sf-btn sf-btn-secondary btn-sm">Deny</button>
                    `;

                    const acceptBtn = buttons.children[0];
                    const denyBtn = buttons.children[1];

                    acceptBtn.addEventListener("click", async () => {
                        try {
                            setStatus("Отправляем accept...", "alert-info");
                            const result = await api(`/api/accounts/${accountId}/guard/confirmations/${conf.id}/${conf.key}/accept`, { method: "POST", body: "{}" });
                            setPayload(result);
                            setStatus("Подтверждение принято.", "alert-success");
                            await refreshConfirmations();
                        } catch (e) {
                            setStatus(`Ошибка accept: ${e.message}`, "alert-danger");
                        }
                    });

                    denyBtn.addEventListener("click", async () => {
                        try {
                            setStatus("Отправляем deny...", "alert-info");
                            const result = await api(`/api/accounts/${accountId}/guard/confirmations/${conf.id}/${conf.key}/deny`, { method: "POST", body: "{}" });
                            setPayload(result);
                            setStatus("Подтверждение отклонено.", "alert-warning");
                            await refreshConfirmations();
                        } catch (e) {
                            setStatus(`Ошибка deny: ${e.message}`, "alert-danger");
                        }
                    });

                    card.appendChild(buttons);
                    confListEl.appendChild(card);
                }
            }

            async function refreshConfirmations() {
                try {
                    setStatus("Загружаем mobile confirmations...", "alert-info");
                    const data = await api(`/api/accounts/${accountId}/guard/confirmations`, { method: "GET" });
                    setPayload(data);
                    renderConfirmations(data.confirmations || []);
                    setStatus(`Получено подтверждений: ${(data.confirmations || []).length}`, "alert-secondary");
                } catch (e) {
                    setStatus(`Не удалось загрузить confirmations: ${e.message}`, "alert-danger");
                }
            }

            linkStartBtn.addEventListener("click", async () => {
                try {
                    setStatus("Запускаем линковку Steam Guard...", "alert-info");
                    const payload = {
                        phoneNumber: phoneInput && phoneInput.value ? phoneInput.value.trim() : null,
                        phoneCountryCode: "7"
                    };
                    const data = await api(`/api/accounts/${accountId}/guard/link/start`, {
                        method: "POST",
                        body: JSON.stringify(payload)
                    });
                    setPayload(data);
                    setStatus(`Шаг: ${data.step || "Unknown"}`, data.success ? "alert-success" : "alert-warning");
                } catch (e) {
                    setStatus(`Линковка не запущена: ${e.message}`, "alert-danger");
                }
            });

            phoneSubmitBtn.addEventListener("click", async () => {
                try {
                    const phoneNumber = phoneInput && phoneInput.value ? phoneInput.value.trim() : "";
                    if (!phoneNumber) {
                        setStatus("Введите телефон перед отправкой.", "alert-warning");
                        return;
                    }

                    setStatus("Отправляем телефон для шага email-confirmation...", "alert-info");
                    const data = await api(`/api/accounts/${accountId}/guard/link/phone`, {
                        method: "POST",
                        body: JSON.stringify({ phoneNumber, phoneCountryCode: "7" })
                    });
                    setPayload(data);
                    setStatus(`Шаг: ${data.step || "Unknown"}`, data.success ? "alert-success" : "alert-warning");
                } catch (e) {
                    setStatus(`Не удалось отправить телефон: ${e.message}`, "alert-danger");
                }
            });

            linkFinalizeBtn.addEventListener("click", async () => {
                try {
                    const smsCode = smsInput && smsInput.value ? smsInput.value.trim() : "";
                    if (!smsCode) {
                        setStatus("Введите SMS-код перед финализацией.", "alert-warning");
                        return;
                    }

                    setStatus("Финализируем линковку...", "alert-info");
                    const data = await api(`/api/accounts/${accountId}/guard/link/finalize`, {
                        method: "POST",
                        body: JSON.stringify({ smsCode })
                    });
                    setPayload(data);
                    setStatus(`Finalize: ${data.step || "Unknown"}`, data.success ? "alert-success" : "alert-warning");
                } catch (e) {
                    setStatus(`Финализация не удалась: ${e.message}`, "alert-danger");
                }
            });

            removeBtn.addEventListener("click", async () => {
                try {
                    const scheme = parseInt(removeScheme && removeScheme.value ? removeScheme.value : "1", 10);
                    setStatus("Удаляем аутентификатор...", "alert-info");
                    const data = await api(`/api/accounts/${accountId}/guard/remove`, {
                        method: "POST",
                        body: JSON.stringify({ scheme })
                    });
                    setPayload(data);
                    setStatus("Аутентификатор удалён.", "alert-success");
                } catch (e) {
                    setStatus(`Не удалось удалить аутентификатор: ${e.message}`, "alert-danger");
                }
            });

            confRefreshBtn.addEventListener("click", refreshConfirmations);
            confAcceptAllBtn.addEventListener("click", async () => {
                try {
                    const current = await api(`/api/accounts/${accountId}/guard/confirmations`, { method: "GET" });
                    const refs = (current.confirmations || []).map(x => ({ id: x.id, key: x.key }));
                    if (refs.length === 0) {
                        setStatus("Нет подтверждений для batch-accept.", "alert-secondary");
                        return;
                    }

                    setStatus(`Batch accept (${refs.length})...`, "alert-info");
                    const result = await api(`/api/accounts/${accountId}/guard/confirmations/accept-batch`, {
                        method: "POST",
                        body: JSON.stringify({ confirmations: refs })
                    });
                    setPayload(result);
                    setStatus("Batch-accept выполнен.", "alert-success");
                    await refreshConfirmations();
                } catch (e) {
                    setStatus(`Batch-accept ошибка: ${e.message}`, "alert-danger");
                }
            });

            refreshConfirmations();
        })();
    </script>
}
