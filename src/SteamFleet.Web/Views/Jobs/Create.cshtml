@model CreateJobFormModel
@{
    ViewData["Title"] = "Создать задачу";
    var operationalSettings = ViewData["OperationalSettings"] as SteamFleet.Contracts.Settings.OperationalSafetySettingsDto
                              ?? new SteamFleet.Contracts.Settings.OperationalSafetySettingsDto();
    var typeHints = new Dictionary<JobType, (string Title, string Description)>
    {
        [JobType.ProfileUpdate] = ("Профиль", "Имя, био, real name, локация, custom URL."),
        [JobType.PrivacyUpdate] = ("Приватность", "Профиль, друзья и инвентарь."),
        [JobType.AvatarUpdate] = ("Аватар", "Файл/URL/base64 с валидацией размера."),
        [JobType.TagsAssign] = ("Теги", "Массовое назначение тегов."),
        [JobType.GroupMove] = ("Папка", "Перемещение в папку."),
        [JobType.AddNote] = ("Заметка", "Добавление рабочей заметки."),
        [JobType.PasswordChange] = ("Смена пароля", "Единый или сгенерированный пароль + deauth."),
        [JobType.SessionsDeauthorize] = ("Деавторизация", "Завершить все сессии."),
        [JobType.SessionValidate] = ("Проверка сессии", "Проверка валидности текущей сессии."),
        [JobType.SessionRefresh] = ("Обновление сессии", "Refresh/re-auth по необходимости."),
        [JobType.FriendsAddByInvite] = ("Друзья по invite", "Пары source -> target по invite-link."),
        [JobType.FriendsConnectFamilyMain] = ("Друзья семьи", "Главный аккаунт + автопоиск family-целей.")
    };
    var totalAccounts = Model.AvailableAccounts.Count;
    var selectedHint = typeHints.TryGetValue(Model.Type, out var currentHint)
        ? currentHint
        : (Model.Type.ToString(), "Без описания");
}

<section class="sf-page-header">
    <div>
        <h1 class="sf-page-title">Конструктор задач</h1>
        <div class="sf-page-subtitle">Выберите тип операции и заполните только нужные поля. JSON-режим не требуется.</div>
    </div>
    <a class="btn sf-btn sf-btn-secondary" asp-action="Index">К списку задач</a>
</section>

<section class="sf-card">
    <div class="sf-card-head">
        <h2 class="sf-title h4 mb-0">Новая batch-задача</h2>
        <div class="sf-subtitle">Типизированные формы для профиля, безопасности, друзей и family-сценариев без ручного JSON.</div>
    </div>
    <div class="sf-card-body">
        <form asp-action="CreatePost" method="post" enctype="multipart/form-data" class="sf-grid" id="jobForm">
            <div asp-validation-summary="ModelOnly" class="text-danger sf-col-12"></div>

            <div class="sf-col-12">
                <div class="sf-job-type-grid" id="jobTypeCards">
                    @foreach (var type in Enum.GetValues<JobType>())
                    {
                        var hint = typeHints.TryGetValue(type, out var mapped)
                            ? mapped
                            : (type.ToString(), "Без описания");
                        var activeClass = Model.Type == type ? "is-active" : null;
                        <button type="button"
                                class="sf-job-type-card @activeClass"
                                data-job-type="@type"
                                data-job-title="@hint.Item1"
                                data-job-description="@hint.Item2">
                            <span class="sf-job-type-title">@hint.Item1</span>
                            <span class="sf-job-type-desc">@hint.Item2</span>
                        </button>
                    }
                </div>
            </div>

            <div class="sf-col-12">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Safe-mode</h2>
                        <div class="sf-subtitle">Ограничения для снижения риска блокировок и login-штормов.</div>
                    </div>
                    <div class="sf-chip-list">
                        <span class="sf-chip"><span class="sf-chip-key">Включен</span><span class="sf-chip-value">@operationalSettings.SafeModeEnabled</span></span>
                        <span class="sf-chip"><span class="sf-chip-key">Parallelism по умолчанию</span><span class="sf-chip-value">@operationalSettings.DefaultJobParallelism</span></span>
                        <span class="sf-chip"><span class="sf-chip-key">Retry по умолчанию</span><span class="sf-chip-value">@operationalSettings.DefaultJobRetryCount</span></span>
                        <span class="sf-chip"><span class="sf-chip-key">Max sensitive parallelism</span><span class="sf-chip-value">@operationalSettings.MaxSensitiveParallelism</span></span>
                        <span class="sf-chip"><span class="sf-chip-key">Max sensitive accounts</span><span class="sf-chip-value">@operationalSettings.MaxSensitiveAccountsPerJob</span></span>
                    </div>
                </section>
            </div>

            <div class="sf-col-12">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Общие параметры</h2>
                        <div class="sf-subtitle">Настройки очереди и выполнения задачи.</div>
                    </div>
                    <div class="sf-grid">
                        <div class="sf-col-4">
                            <label class="form-label" asp-for="Type"></label>
                            <input type="hidden" id="jobType" name="Type" value="@Model.Type" />
                            <div id="selectedTypeLabel" class="form-control d-flex align-items-center">
                                @selectedHint.Item1 (@Model.Type)
                            </div>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>
                        <div class="sf-col-2">
                            <label class="form-label" asp-for="Parallelism"></label>
                            <input asp-for="Parallelism" class="form-control" min="1" max="50" />
                            <span asp-validation-for="Parallelism" class="text-danger"></span>
                        </div>
                        <div class="sf-col-2">
                            <label class="form-label" asp-for="RetryCount"></label>
                            <input asp-for="RetryCount" class="form-control" min="0" max="10" />
                            <span asp-validation-for="RetryCount" class="text-danger"></span>
                        </div>
                        <div class="sf-col-4 js-type js-password">
                            <label class="form-label" asp-for="GeneratePasswordLength"></label>
                            <input asp-for="GeneratePasswordLength" class="form-control" min="12" max="64" />
                            <span asp-validation-for="GeneratePasswordLength" class="text-danger"></span>
                        </div>
                        <div class="sf-col-12 d-flex gap-4 flex-wrap align-items-center">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="DryRun" />
                                <label class="form-check-label" asp-for="DryRun"></label>
                            </div>
                            <div class="form-check js-type js-password">
                                <input class="form-check-input" asp-for="DeauthorizeAfterChange" />
                                <label class="form-check-label" asp-for="DeauthorizeAfterChange"></label>
                            </div>
                        </div>
                        <div class="sf-col-12">
                            <div class="sf-advanced-box">
                                <strong id="selectedTypeTitle">@selectedHint.Item1</strong>
                                <div id="selectedTypeDescription" class="sf-subtitle mt-1">@selectedHint.Item2</div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="sf-col-12 js-type js-account-select">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h2 class="sf-inline-title">Аккаунты для задачи</h2>
                            <div class="sf-subtitle">Выбрано: <span id="selectedAccountsCount">0</span> из @totalAccounts.</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <button type="button" class="btn sf-btn sf-btn-secondary btn-sm" id="selectAllAccounts">Выбрать все</button>
                            <button type="button" class="btn sf-btn sf-btn-secondary btn-sm" id="clearAllAccounts">Снять все</button>
                        </div>
                    </div>
                    <div class="sf-grid">
                        <div class="sf-col-12">
                            <input type="text" class="form-control" id="accountSearchInput" placeholder="Поиск по login, display name или статусу..." />
                        </div>
                        <div class="sf-col-12">
                            <div class="sf-account-picker" id="accountPicker">
                                @foreach (var account in Model.AvailableAccounts)
                                {
                                    var display = string.IsNullOrWhiteSpace(account.DisplayName)
                                        ? "без display name"
                                        : account.DisplayName;
                                    var selected = Model.SelectedAccountIds.Contains(account.Id) ? "checked" : null;
                                    <label class="sf-account-item"
                                           data-search="@($"{account.LoginName} {display} {account.Status}".ToLowerInvariant())">
                                        <input class="form-check-input account-checkbox"
                                               type="checkbox"
                                               name="SelectedAccountIds"
                                               value="@account.Id"
                                               checked="@selected" />
                                        <span>
                                            <span class="sf-account-item-title">@account.LoginName</span>
                                            <span class="sf-account-item-meta">@display</span>
                                            <span class="sf-account-item-meta">Статус: @account.Status</span>
                                        </span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="SelectedAccountIds" class="text-danger"></span>
                        </div>
                    </div>
                </section>
            </div>

            <div class="sf-col-12 js-type js-profile">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Профиль Steam</h2>
                        <div class="sf-subtitle">Можно менять имя, описание, real name, локацию и custom URL в одном запуске.</div>
                    </div>
                    <div class="sf-form-mini-grid">
                        <article class="sf-mini-card">
                            <label class="form-label" asp-for="DisplayName"></label>
                            <input asp-for="DisplayName" class="form-control" placeholder="Новое отображаемое имя" />
                            <span asp-validation-for="DisplayName" class="text-danger"></span>
                            <div class="form-text">Главное поле для «смены имени» в профиле.</div>
                        </article>
                        <article class="sf-mini-card">
                            <label class="form-label" asp-for="Summary"></label>
                            <textarea asp-for="Summary" class="form-control" rows="3" placeholder="Короткое описание профиля"></textarea>
                            <span asp-validation-for="Summary" class="text-danger"></span>
                        </article>
                        <article class="sf-mini-card">
                            <label class="form-label" asp-for="RealName"></label>
                            <input asp-for="RealName" class="form-control" placeholder="Имя из профиля Steam" />
                            <span asp-validation-for="RealName" class="text-danger"></span>
                        </article>
                        <article class="sf-mini-card">
                            <label class="form-label" asp-for="CustomUrl"></label>
                            <input asp-for="CustomUrl" class="form-control" placeholder="custom-vanity-url" />
                            <span asp-validation-for="CustomUrl" class="text-danger"></span>
                        </article>
                        <article class="sf-mini-card sf-mini-card-wide">
                            <div class="sf-mini-card-title">Локация</div>
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label" asp-for="Country"></label>
                                    <input asp-for="Country" class="form-control" placeholder="RU / US / ..." />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label" asp-for="State"></label>
                                    <input asp-for="State" class="form-control" placeholder="Moscow / California" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label" asp-for="City"></label>
                                    <input asp-for="City" class="form-control" placeholder="Москва / Seattle" />
                                </div>
                            </div>
                            <span asp-validation-for="Country" class="text-danger"></span>
                            <span asp-validation-for="State" class="text-danger"></span>
                            <span asp-validation-for="City" class="text-danger"></span>
                        </article>
                    </div>
                </section>
            </div>

            <div class="sf-col-12 js-type js-privacy">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Приватность</h2>
                        <div class="sf-subtitle">Выберите только те флаги, которые нужно изменить. Пустое значение = без изменений.</div>
                    </div>
                    <div class="sf-form-mini-grid">
                        <article class="sf-mini-card">
                            <label class="form-label" asp-for="ProfilePrivate"></label>
                            <select asp-for="ProfilePrivate" class="form-select">
                                <option value="">Не менять</option>
                                <option value="true">Приватный</option>
                                <option value="false">Публичный</option>
                            </select>
                            <span asp-validation-for="ProfilePrivate" class="text-danger"></span>
                        </article>
                        <article class="sf-mini-card">
                            <label class="form-label" asp-for="FriendsPrivate"></label>
                            <select asp-for="FriendsPrivate" class="form-select">
                                <option value="">Не менять</option>
                                <option value="true">Приватный</option>
                                <option value="false">Публичный</option>
                            </select>
                            <span asp-validation-for="FriendsPrivate" class="text-danger"></span>
                        </article>
                        <article class="sf-mini-card">
                            <label class="form-label" asp-for="InventoryPrivate"></label>
                            <select asp-for="InventoryPrivate" class="form-select">
                                <option value="">Не менять</option>
                                <option value="true">Приватный</option>
                                <option value="false">Публичный</option>
                            </select>
                            <span asp-validation-for="InventoryPrivate" class="text-danger"></span>
                        </article>
                    </div>
                </section>
            </div>

            <div class="sf-col-12 js-type js-avatar">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Смена аватара</h2>
                        <div class="sf-subtitle">Приоритет источников: файл -> URL -> avatarBase64. Максимальный размер: 2 МБ.</div>
                    </div>
                    <div class="sf-grid">
                        <div class="sf-col-6">
                            <label class="form-label" asp-for="AvatarFile"></label>
                            <input asp-for="AvatarFile" class="form-control" type="file" accept="image/*" />
                            <span asp-validation-for="AvatarFile" class="text-danger"></span>
                        </div>
                        <div class="sf-col-6">
                            <label class="form-label" asp-for="AvatarUrl"></label>
                            <input asp-for="AvatarUrl" class="form-control" placeholder="https://example.com/avatar.png" />
                            <span asp-validation-for="AvatarUrl" class="text-danger"></span>
                        </div>
                        <div class="sf-col-12">
                            <details class="sf-advanced-box">
                                <summary>Расширенный режим: base64</summary>
                                <label class="form-label mt-2" asp-for="AvatarBase64"></label>
                                <textarea asp-for="AvatarBase64" class="form-control" rows="3" placeholder="iVBORw0KGgo..."></textarea>
                                <span asp-validation-for="AvatarBase64" class="text-danger"></span>
                            </details>
                        </div>
                    </div>
                </section>
            </div>

            <div class="sf-col-12 js-type js-tags">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Назначение тегов</h2>
                        <div class="sf-subtitle">Разделители: запятая, `;` или `|`.</div>
                    </div>
                    <label class="form-label" asp-for="TagsRaw"></label>
                    <input asp-for="TagsRaw" class="form-control" placeholder="фарм,основной,manual-check" />
                    <span asp-validation-for="TagsRaw" class="text-danger"></span>
                </section>
            </div>

            <div class="sf-col-12 js-type js-group">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Перемещение в папку</h2>
                    </div>
                    <label class="form-label" asp-for="FolderName"></label>
                    <input asp-for="FolderName" class="form-control" placeholder="farm-accounts / region-eu / ..." />
                    <span asp-validation-for="FolderName" class="text-danger"></span>
                </section>
            </div>

            <div class="sf-col-12 js-type js-note">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Добавить заметку</h2>
                    </div>
                    <label class="form-label" asp-for="NoteText"></label>
                    <textarea asp-for="NoteText" class="form-control" rows="4" placeholder="Комментарий к аккаунтам..."></textarea>
                    <span asp-validation-for="NoteText" class="text-danger"></span>
                </section>
            </div>

            <div class="sf-col-12 js-type js-password">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Смена пароля</h2>
                        <div class="sf-subtitle">Если поле пароля пустое, для каждого аккаунта сгенерируется свой уникальный пароль.</div>
                    </div>
                    <div class="sf-grid">
                        <div class="sf-col-6">
                            <label class="form-label" asp-for="FixedNewPassword"></label>
                            <input asp-for="FixedNewPassword" class="form-control" autocomplete="off" />
                            <span asp-validation-for="FixedNewPassword" class="text-danger"></span>
                        </div>
                        <div class="sf-col-6 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="DeauthorizeAfterChange" />
                                <label class="form-check-label" asp-for="DeauthorizeAfterChange"></label>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="sf-col-12 js-type js-friends-add">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h2 class="sf-inline-title">Friends: add by invite</h2>
                            <div class="sf-subtitle">Для каждой пары source генерирует invite-link, target принимает приглашение.</div>
                        </div>
                        <button type="button" class="btn sf-btn sf-btn-secondary btn-sm" id="addFriendPair">Добавить пару</button>
                    </div>
                    <div id="friendsPairsContainer" class="d-flex flex-column gap-2">
                        @for (var i = 0; i < Model.FriendsPairs.Count; i++)
                        {
                            <div class="row g-2 js-friend-pair-row" data-index="@i">
                                <div class="col-md-5">
                                    <label class="form-label">Source аккаунт</label>
                                    <select class="form-select" name="FriendsPairs[@i].SourceAccountId">
                                        <option value="">Выберите source</option>
                                        @foreach (var account in Model.AvailableAccounts)
                                        {
                                            var selected = Model.FriendsPairs[i].SourceAccountId == account.Id ? "selected" : null;
                                            var display = string.IsNullOrWhiteSpace(account.DisplayName) ? "без display name" : account.DisplayName;
                                            <option value="@account.Id" selected="@selected">@account.LoginName (@display)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label">Target аккаунт</label>
                                    <select class="form-select" name="FriendsPairs[@i].TargetAccountId">
                                        <option value="">Выберите target</option>
                                        @foreach (var account in Model.AvailableAccounts)
                                        {
                                            var selected = Model.FriendsPairs[i].TargetAccountId == account.Id ? "selected" : null;
                                            var display = string.IsNullOrWhiteSpace(account.DisplayName) ? "без display name" : account.DisplayName;
                                            <option value="@account.Id" selected="@selected">@account.LoginName (@display)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2 d-grid align-items-end">
                                    <button type="button" class="btn sf-btn sf-btn-danger btn-sm js-remove-friend-pair">Удалить</button>
                                </div>
                            </div>
                        }
                    </div>
                    <span asp-validation-for="FriendsPairs" class="text-danger"></span>
                </section>
            </div>

            <div class="sf-col-12 js-type js-friends-family">
                <section class="sf-inline-section">
                    <div class="sf-inline-section-head">
                        <h2 class="sf-inline-title">Friends: connect family</h2>
                        <div class="sf-subtitle">Выберите main-аккаунт. Цели подтягиваются автоматически из синхронизированной Steam Family.</div>
                    </div>
                    <label class="form-label" asp-for="FamilyMainAccountId"></label>
                    <select asp-for="FamilyMainAccountId" class="form-select">
                        <option value="">Выберите главный аккаунт</option>
                        @foreach (var main in Model.MainAccountOptions)
                        {
                            var display = string.IsNullOrWhiteSpace(main.DisplayName) ? "без display name" : main.DisplayName;
                            <option value="@main.Id">@main.LoginName (@display) — @main.Status</option>
                        }
                    </select>
                    <span asp-validation-for="FamilyMainAccountId" class="text-danger"></span>
                </section>
            </div>

            <div class="sf-col-12 d-flex gap-2">
                <button class="btn sf-btn sf-btn-primary" type="submit">Запустить задачу</button>
                <a class="btn sf-btn sf-btn-secondary" asp-action="Index">Отмена</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const typeInput = document.getElementById("jobType");
            const typeLabel = document.getElementById("selectedTypeLabel");
            const typeTitle = document.getElementById("selectedTypeTitle");
            const typeDescription = document.getElementById("selectedTypeDescription");
            const typeCards = Array.from(document.querySelectorAll(".sf-job-type-card"));
            const allBlocks = Array.from(document.querySelectorAll(".js-type"));
            const accountCheckboxes = () => Array.from(document.querySelectorAll(".account-checkbox"));
            const selectedCount = document.getElementById("selectedAccountsCount");
            const accountSearch = document.getElementById("accountSearchInput");
            const accountItems = Array.from(document.querySelectorAll(".sf-account-item"));
            const selectAllButton = document.getElementById("selectAllAccounts");
            const clearAllButton = document.getElementById("clearAllAccounts");
            if (!typeInput || !typeCards.length) {
                return;
            }

            const groups = {
                ProfileUpdate: [".js-profile", ".js-account-select"],
                PrivacyUpdate: [".js-privacy", ".js-account-select"],
                AvatarUpdate: [".js-avatar", ".js-account-select"],
                TagsAssign: [".js-tags", ".js-account-select"],
                GroupMove: [".js-group", ".js-account-select"],
                AddNote: [".js-note", ".js-account-select"],
                PasswordChange: [".js-password", ".js-account-select"],
                SessionsDeauthorize: [".js-account-select"],
                SessionValidate: [".js-account-select"],
                SessionRefresh: [".js-account-select"],
                FriendsAddByInvite: [".js-friends-add"],
                FriendsConnectFamilyMain: [".js-friends-family"]
            };
            const defaultType = "SessionValidate";

            function normalizeType(rawValue) {
                const raw = (rawValue || "").trim();
                if (!raw) {
                    return "";
                }

                const exact = Object.keys(groups).find(x => x === raw);
                if (exact) {
                    return exact;
                }

                const lowered = raw.toLowerCase();
                const matched = Object.keys(groups).find(x => x.toLowerCase() === lowered);
                return matched || "";
            }

            function renderTypeMeta(type) {
                const card = typeCards.find(x => x.dataset.jobType === type);
                const title = card?.dataset.jobTitle || type;
                const description = card?.dataset.jobDescription || "Описание типа задачи недоступно.";
                if (typeLabel) {
                    typeLabel.textContent = `${title} (${type})`;
                }
                if (typeTitle) {
                    typeTitle.textContent = title;
                }
                if (typeDescription) {
                    typeDescription.textContent = description;
                }
            }

            function setType(nextType) {
                const normalized = normalizeType(nextType) || defaultType;
                typeInput.value = normalized;
                updateTypeVisibility();
            }

            function updateSelectedCount() {
                if (!selectedCount) {
                    return;
                }

                const count = accountCheckboxes().filter(x => x.checked).length;
                selectedCount.textContent = String(count);
            }

            function updateTypeVisibility() {
                const type = normalizeType(typeInput.value) || defaultType;
                typeInput.value = type;
                allBlocks.forEach(el => {
                    el.style.display = "none";
                });

                (groups[type] || [".js-account-select"]).forEach(selector => {
                    document.querySelectorAll(selector).forEach(el => {
                        el.style.display = "";
                    });
                });

                typeCards.forEach(card => {
                    card.classList.toggle("is-active", card.dataset.jobType === type);
                });
                renderTypeMeta(type);
            }

            typeCards.forEach(card => {
                card.addEventListener("click", () => {
                    const nextType = card.dataset.jobType;
                    if (!nextType) {
                        return;
                    }
                    setType(nextType);
                });
            });

            accountCheckboxes().forEach(cb => cb.addEventListener("change", updateSelectedCount));

            selectAllButton?.addEventListener("click", () => {
                accountItems.forEach(item => {
                    if (item.style.display === "none") {
                        return;
                    }

                    const input = item.querySelector("input[type='checkbox']");
                    if (input) {
                        input.checked = true;
                    }
                });
                updateSelectedCount();
            });

            clearAllButton?.addEventListener("click", () => {
                accountItems.forEach(item => {
                    if (item.style.display === "none") {
                        return;
                    }

                    const input = item.querySelector("input[type='checkbox']");
                    if (input) {
                        input.checked = false;
                    }
                });
                updateSelectedCount();
            });

            accountSearch?.addEventListener("input", () => {
                const query = accountSearch.value.trim().toLowerCase();
                accountItems.forEach(item => {
                    const haystack = item.dataset.search || "";
                    item.style.display = !query || haystack.includes(query) ? "" : "none";
                });
            });

            const pairsContainer = document.getElementById("friendsPairsContainer");
            const addPairButton = document.getElementById("addFriendPair");

            function reindexPairs() {
                if (!pairsContainer) {
                    return;
                }

                const rows = pairsContainer.querySelectorAll(".js-friend-pair-row");
                rows.forEach((row, index) => {
                    row.dataset.index = String(index);
                    row.querySelectorAll("select").forEach(select => {
                        if (select.name.includes("SourceAccountId")) {
                            select.name = `FriendsPairs[${index}].SourceAccountId`;
                        }
                        if (select.name.includes("TargetAccountId")) {
                            select.name = `FriendsPairs[${index}].TargetAccountId`;
                        }
                    });
                });
            }

            function bindPairButtons() {
                if (!pairsContainer) {
                    return;
                }

                pairsContainer.querySelectorAll(".js-remove-friend-pair").forEach(btn => {
                    btn.onclick = () => {
                        const rows = pairsContainer.querySelectorAll(".js-friend-pair-row");
                        if (rows.length <= 1) {
                            return;
                        }

                        btn.closest(".js-friend-pair-row")?.remove();
                        reindexPairs();
                    };
                });
            }

            addPairButton?.addEventListener("click", () => {
                if (!pairsContainer) {
                    return;
                }

                const firstRow = pairsContainer.querySelector(".js-friend-pair-row");
                if (!firstRow) {
                    return;
                }

                const clone = firstRow.cloneNode(true);
                clone.querySelectorAll("select").forEach(select => {
                    select.value = "";
                });
                pairsContainer.appendChild(clone);
                reindexPairs();
                bindPairButtons();
            });

            bindPairButtons();
            setType(typeInput.value);
            updateSelectedCount();
        })();
    </script>
}
